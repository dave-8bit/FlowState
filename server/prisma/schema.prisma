// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model User {
  id        String   @id @default(cuid())
  githubId  String   @unique
  username  String
  avatarUrl String?
  createdAt DateTime @default(now())

  tasks                 Task[]
  focusSessions         FocusSession[] @relation("FocusSession_creator")
  sessionParticipants   SessionParticipant[]
  analytics             Analytics?
}

model Task {
  id          String      @id @default(cuid())
  userId      String
  title       String
  description String?
  priority    TaskPriority
  status      TaskStatus
  deadline    DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user                User                  @relation(fields: [userId], references: [id])
  sessionParticipants SessionParticipant[]
}

model FocusSession {
  id           String @id @default(cuid())
  creatorId    String
  title        String
  timerMinutes Int    @default(25)
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())

  creator      User @relation("FocusSession_creator", fields: [creatorId], references: [id])
  participants SessionParticipant[]
}

model SessionParticipant {
  id        String @id @default(cuid())
  sessionId String
  userId    String
  taskId    String?
  joinedAt  DateTime @default(now())

  session FocusSession @relation(fields: [sessionId], references: [id])
  user    User         @relation(fields: [userId], references: [id])
  task    Task?        @relation(fields: [taskId], references: [id])

  @@index([sessionId])
  @@index([userId])
  @@index([taskId])
}

model Analytics {
  id                 String   @id @default(cuid())
  userId             String   @unique
  tasksCompleted    Int      @default(0)
  tasksAbandoned    Int      @default(0)
  totalFocusMinutes Int      @default(0)
  currentStreak      Int      @default(0)
  brainDumpCount    Int      @default(0)
  lastActiveAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

